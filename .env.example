# ============================================================
# COLOUR IMPRESSIONS — Plant Management System
# .env.local — Copy this file, fill in values, never commit it
# ============================================================

# ── DATABASE (Neon PostgreSQL) ──
DATABASE_URL="postgresql://[user]:[password]@[host].neon.tech/ci_plant?sslmode=require"

# ── NEXT AUTH ──
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"
NEXTAUTH_URL="http://localhost:3000"
# Production: NEXTAUTH_URL="https://app.colourimpressions.in"

# ── CLOUDFLARE R2 (File Storage) ──
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key"
R2_SECRET_ACCESS_KEY="your-r2-secret-key"
R2_BUCKET_NAME="ci-plant-files"
R2_PUBLIC_URL="https://your-bucket.r2.dev"

# ── WATI (WhatsApp Business API) ──
WATI_API_KEY="your-wati-api-key"
WATI_BASE_URL="https://live-server.wati.io"

# ── RESEND (vendor material PO PDF email) ──
# Use a verified sender domain in Resend; from must match that domain.
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="procurement@your-verified-domain.com"

# ── APP CONFIG ──
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="CI Plant System"

# ── OPTIONAL: Daily MD summary cron (Vercel Cron) ──
CRON_SECRET="generate-with: openssl rand -base64 16"
