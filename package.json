{
  "name": "ci-plant-system",
  "version": "1.0.0",
  "description": "Colour Impressions Plant Management System",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "next dev --port 3000 --hostname 0.0.0.0",
    "dev:fresh": "lsof -ti :3000 | xargs kill -9 2>/dev/null; sleep 2; next dev --port 3000 --hostname 0.0.0.0",
    "build": "prisma generate && next build",
    "postbuild": "node -e \"const fs=require('fs');const f='.next/server/app/(dashboard)/page_client-reference-manifest.js';fs.mkdirSync(require('path').dirname(f),{recursive:true});fs.existsSync(f)||fs.writeFileSync(f,'{}');\"",
    "start": "next start",
    "lint": "next lint",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate",
    "test:hub-qa": "tsx scripts/hub-qa-test.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1009.0",
    "@ci/payroll-core": "file:packages/payroll-core",
    "@ci/request-utils": "file:packages/request-utils",
    "@hookform/resolvers": "^3.6.0",
    "@prisma/client": "^5.14.0",
    "@react-pdf/renderer": "^3.4.4",
    "@tanstack/react-query": "^5.45.0",
    "@tanstack/react-table": "^8.21.3",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "html5-qrcode": "^2.3.8",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.395.0",
    "nanoid": "^5.0.7",
    "next": "^14.2.0",
    "next-auth": "^4.24.7",
    "next-themes": "^0.4.6",
    "prisma": "^5.14.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-hook-form": "^7.52.0",
    "recharts": "^2.12.7",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.3.0",
    "xlsx": "^0.18.5",
    "zod": "^3.23.8",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.7",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.14.2",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "tsx": "^4.15.6",
    "typescript": "^5.4.5"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
