// ─────────────────────────────────────────

model WasteRecord {
  id          String   @id @default(uuid())
  jobId       String   @map("job_id")
  stageId     String?  @map("stage_id")
  wasteType   String   @map("waste_type") @db.VarChar(40) // makeready | run_waste | substrate_trim
  qty         Decimal  @db.Decimal(12, 3)
  unit        String   @db.VarChar(20)
  materialId  String   @map("material_id")
  machineId   String?  @map("machine_id")
  recordedBy  String   @map("recorded_by")
  recordedAt  DateTime @default(now()) @map("recorded_at")

  job      Job        @relation(fields: [jobId], references: [id])
  stage    JobStage?  @relation(fields: [stageId], references: [id])
  material Inventory  @relation(fields: [materialId], references: [id])
  machine  Machine?   @relation(fields: [machineId], references: [id])
  recorder User       @relation(fields: [recordedBy], references: [id])

  @@map("waste_records")
}

// ─────────────────────────────────────────
// PURCHASE REQUISITIONS
// ─────────────────────────────────────────

model PurchaseRequisition {
  id               String    @id @default(uuid())
  materialId       String    @map("material_id")
  qtyRequired      Decimal   @map("qty_required") @db.Decimal(12, 3)
  estimatedValue   Decimal   @default(0) @map("estimated_value") @db.Decimal(12, 2)
  triggerReason    String    @map("trigger_reason")
  status           String    @default("pending") @db.VarChar(30) // pending | approved | converted_to_po | rejected
  raisedBy         String    @map("raised_by")
  raisedAt         DateTime  @default(now()) @map("raised_at")
  approvedBy       String?   @map("approved_by")
  approvedAt       DateTime? @map("approved_at")
  supplierId       String?   @map("supplier_id")
  expectedDelivery DateTime? @map("expected_delivery") @db.Date
  poReference      String?   @map("po_reference") @db.VarChar(60)
  createdAt        DateTime  @default(now()) @map("created_at")

  material Inventory @relation(fields: [materialId], references: [id])

  @@map("purchase_requisitions")
}

// ─────────────────────────────────────────
// STOCK MOVEMENTS (activity log)
// ─────────────────────────────────────────

model StockMovement {
  id           String   @id @default(uuid())
  materialId   String   @map("material_id")
  movementType String   @map("movement_type") @db.VarChar(40) // grn_quarantine | qa_release | reserve | issue | consume | fg_receipt | dispatch
  qty          Decimal  @db.Decimal(12, 3)
  refType      String?  @map("ref_type") @db.VarChar(40)
  refId        String?  @map("ref_id")
  userId       String?  @map("user_id")
  createdAt    DateTime @default(now()) @map("created_at")

  material Inventory @relation(fields: [materialId], references: [id])

  @@map("stock_movements")
}
