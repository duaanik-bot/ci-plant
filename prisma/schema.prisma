// ─────────────────────────────────────────
// PLATE STORE (Pre-press)
// ─────────────────────────────────────────

model PlateStore {
  id              String    @id @default(uuid())
  /// DB column `current_job_card_id` (see initial migration); links plate set to production job card.
  jobCardId       String?   @map("current_job_card_id")
  cartonId        String?   @map("carton_id")
  artworkId       String?   @map("artwork_id")
  artworkCode     String?   @map("artwork_code")
  artworkVersion  String?   @map("artwork_version")
  cartonName      String    @map("carton_name")
  customerId      String?   @map("customer_id")
  plateSetCode    String    @unique @map("plate_set_code")
  serialNumber    String?   @map("serial_number")
  outputNumber    String?   @map("output_number")
  rackNumber      String?   @map("rack_number")
  ups             Int?      @map("ups")
  numberOfColours Int       @map("number_of_colours")
  colours         Json
  totalPlates     Int       @map("total_plates")
  newPlates       Int       @default(0) @map("new_plates")
  oldPlates       Int       @default(0) @map("old_plates")
  rackLocation    String?   @map("rack_location")
  slotNumber      String?   @map("slot_number")
  storageLocation String?   @map("storage_location")
  ctpOperator     String?   @map("ctp_operator")
  ctpDate         DateTime? @map("ctp_date") @db.Date
  status          String    @default("in_use") @map("status") @db.VarChar(24)
  printedOn       DateTime? @map("printed_on") @db.Date
  collectedBy     String?   @map("collected_by")
  collectedAt     DateTime? @map("collected_at")
  issuedTo        String?   @map("issued_to")
  issuedAt        DateTime? @map("issued_at")
  returnedBy      String?   @map("returned_by")
  returnedAt      DateTime? @map("returned_at")
  storageNotes    String?   @map("storage_notes")
  destroyedReason String?   @map("destroyed_reason")
  destroyedBy     String?   @map("destroyed_by")
  destroyedAt     DateTime? @map("destroyed_at")
  totalImpressions Int      @default(0) @map("total_impressions")
  lastUsedDate    DateTime? @map("last_used_date") @db.Date
  /// Plate Hub staging: ctp | vendor | rack — set when status is READY_ON_FLOOR
  hubCustodySource   String?  @map("hub_custody_source") @db.VarChar(32)
  /// Status before Mark Plate Ready (for reverse)
  hubPreviousStatus  String?  @map("hub_previous_status") @db.VarChar(32)
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  carton            Carton?           @relation(fields: [cartonId], references: [id])
  createdForJobCard ProductionJobCard? @relation("PlateSetCreatedFor", fields: [jobCardId], references: [id])
  customer          Customer?          @relation(fields: [customerId], references: [id])
  jobCardsUsingThis ProductionJobCard[] @relation("PlateSetUsedBy")
  scrapEvents     PlateStoreScrapEvent[]

  @@map("plate_store")
}

/// Audit log for partial / channel-level plate scrapping from Plate Hub.
